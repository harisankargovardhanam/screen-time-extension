{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "short_name": "Screen Time",
  "version": "1.1.1",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "author": "Harisankar",
  "homepage_url": "https://www.linkedin.com/in/harisankarrpm/",
  "permissions": ["tabs", "storage", "alarms", "notifications", "idle", "favicon"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["activity.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Site Time Tracker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
