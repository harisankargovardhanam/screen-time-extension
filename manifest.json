{
  "manifest_version": 3,
  "name": "Screen Time: Website Tracker, Limits & Focus",
  "short_name": "Screen Time",
  "version": "1.0.0",
  "description": "See where your time goes. Live site timers, daily limits with blocking, focus sessions & insights. 100% private, fully local.",
  "author": "Harisankar",
  "homepage_url": "https://www.linkedin.com/in/harisankarrpm/",
  "permissions": ["tabs", "storage", "alarms", "notifications", "idle", "favicon"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["activity.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Site Time Tracker"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
